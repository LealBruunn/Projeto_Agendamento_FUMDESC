# ⚠️ CONFIGURAÇÕES CRÍTICAS DE SEGURANÇA
# Copie este arquivo para .env e preencha com seus valores

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente (development ou production)
NODE_ENV=development

# Token de autenticação para rotas admin
# ⚠️ MUDE ISSO EM PRODUÇÃO! Use uma senha forte e aleatória
# Gerar em: https://1password.com/password-generator/
ADMIN_TOKEN=sua_senha_super_secreta_aqui_123456

# URLs permitidas (CORS) - Separadas por vírgula
# Em produção, remova localhost
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://seu-dominio.com

# URL do frontend (para redirecionamento)
FRONTEND_URL=http://localhost:3000

